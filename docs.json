{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "itellicoAI",
  "colors": {
    "primary": "#E10489",
    "light": "#E10489",
    "dark": "#E10489"
  },
  "favicon": {
    "light": "/light.svg",
    "dark": "/dark.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "essentials/settings",
                  "essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/reusable-snippets"
                ]
              },
              {
                "group": "AI tools",
                "pages": [
                  "ai-tools/cursor",
                  "ai-tools/claude-code",
                  "ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "openapi": "https://api.itellico.ai/v1/openapi.json",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "api-reference/introduction"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "de",
        "tabs": [
          {
            "tab": "Anleitungen",
            "groups": [
              {
                "group": "Erste Schritte",
                "pages": [
                  "de/index",
                  "de/quickstart",
                  "de/development"
                ]
              },
              {
                "group": "Anpassung",
                "pages": [
                  "de/essentials/settings",
                  "de/essentials/navigation"
                ]
              },
              {
                "group": "Inhalte schreiben",
                "pages": [
                  "de/essentials/markdown",
                  "de/essentials/code",
                  "de/essentials/images",
                  "de/essentials/reusable-snippets"
                ]
              },
              {
                "group": "KI-Tools",
                "pages": [
                  "de/ai-tools/cursor",
                  "de/ai-tools/claude-code",
                  "de/ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API-Referenz",
            "openapi": "https://api.itellico.ai/v1/openapi.json",
            "groups": [
              {
                "group": "Erste Schritte",
                "pages": [
                  "de/api-reference/introduction"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://itellico.ai"
  },
  "navbar": {
    "links": [
      {
        "label": "Homepage",
        "href": "https://itellico.ai"
      },
      {
        "label": "Support",
        "href": "https://support.itellico.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.itellico.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/itellicoai",
      "github": "https://github.com/itellicoai",
      "linkedin": "https://linkedin.com/company/itellicoai"
    }
  },
  "background": {
    "decoration": "grid"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "source": "/fonts/Inter-Bold.woff2",
      "format": "woff2",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "source": "/fonts/Inter-Regular.woff2",
      "format": "woff2",
      "weight": 400
    }
  }
}